@page "/"
@layout DashboardLayout

<PageTitle>DB 추출 및 영업점수 계산</PageTitle>

<div class="d-flex flex-column pa-2" style="gap: 8px; overflow: hidden; height: calc(100vh - 110px);">

    @* --- 상단 검색 필터 --- *@
    <MudPaper Class="d-flex align-center pa-2 px-4" Style="background-color: #24242e; border: 1px solid #3d3d4b; gap: 24px; flex-shrink: 0; border-radius: 4px;">
        <div class="d-flex align-center" style="gap: 8px;">
            <MudText Typo="Typo.body2" Style="color: #bbb; font-weight: bold; white-space: nowrap;">날짜</MudText>
            <MudDatePicker @bind-Date="_startDate" DateFormat="yyyy-MM-dd" Margin="Margin.Dense" Variant="Variant.Outlined" Style="background-color: #1e1e24; color: white;" Class="search-date-picker" />
            <MudText Typo="Typo.body2" Style="color: #bbb;">~</MudText>
            <MudDatePicker @bind-Date="_endDate" DateFormat="yyyy-MM-dd" Margin="Margin.Dense" Variant="Variant.Outlined" Style="background-color: #1e1e24; color: white;" Class="search-date-picker" />
        </div>

        <div class="d-flex align-center" style="gap: 8px;">
            <MudText Typo="Typo.body2" Style="color: #bbb; font-weight: bold; white-space: nowrap;">지역</MudText>
            <MudSelect T="string" @bind-Value="_selectedRegion1" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true" Style="background-color: #1e1e24; color: white;" Class="search-select">
                <MudSelectItem Value="@("전국")">전국</MudSelectItem>
                <MudSelectItem Value="@("서울")">서울</MudSelectItem>
                <MudSelectItem Value="@("경기")">경기</MudSelectItem>
                <MudSelectItem Value="@("부산")">부산</MudSelectItem>
            </MudSelect>
            <MudSelect T="string" @bind-Value="_selectedRegion2" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true" Style="background-color: #1e1e24; color: white;" Class="search-select">
                <MudSelectItem Value="@("전체")">전체</MudSelectItem>
                <MudSelectItem Value="@("강남구")">강남구</MudSelectItem>
                <MudSelectItem Value="@("서초구")">서초구</MudSelectItem>
            </MudSelect>
        </div>

        <div class="d-flex align-center" style="gap: 8px;">
            <MudText Typo="Typo.body2" Style="color: #bbb; font-weight: bold; white-space: nowrap;">업종</MudText>
            <MudSelect T="string" @bind-Value="_selectedIndustry" Margin="Margin.Dense" Variant="Variant.Outlined" Dense="true" Style="background-color: #1e1e24; color: white;" Class="search-select-md">
                <MudSelectItem Value="@("-전체-")">-전체-</MudSelectItem>
                <MudSelectItem Value="@("정보통신업")">정보통신업</MudSelectItem>
                <MudSelectItem Value="@("제조업")">제조업</MudSelectItem>
                <MudSelectItem Value="@("도소매업")">도소매업</MudSelectItem>
                <MudSelectItem Value="@("건설업")">건설업</MudSelectItem>
                <MudSelectItem Value="@("전문과학기술")">전문과학기술</MudSelectItem>
            </MudSelect>
        </div>

        <div class="d-flex align-center" style="gap: 8px;">
            <MudText Typo="Typo.body2" Style="color: #bbb; font-weight: bold; white-space: nowrap;">상호</MudText>
            <MudTextField @bind-Value="_searchCompanyName" Placeholder="상호명 입력" Margin="Margin.Dense" Variant="Variant.Outlined" Style="background-color: #1e1e24;" Class="search-text-field" />
        </div>
    </MudPaper>

    @* --- 메인 패널: 작업 결과 --- *@
    <MudPaper Class="d-flex flex-column flex-grow-1" Style="min-width: 0; position: relative; background-color: #1e1e24; color: #fff; overflow: hidden; border: 1px solid #3d3d4b;">
        
        @* --- 상단 영업 타겟 필터 --- *@
        <div class="d-flex align-center pa-2" style="background-color: #24242e; border-bottom: 1px solid #3d3d4b; gap: 16px;">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.FilterList" Color="Color.Warning" Size="Size.Small" Class="mr-1" />
                <MudText Typo="Typo.subtitle2" Style="font-weight: bold; color: #ffb74d; white-space: nowrap;">영업 타겟 필터</MudText>
            </div>
            
            <div class="d-flex align-center flex-wrap" style="gap: 16px;">
                <MudCheckBox @bind-Checked="_filterSalesScore70" Label="Sales Score 70↑" Color="Color.Error" Dense="true" Class="custom-checkbox ma-0" />
                <MudCheckBox @bind-Checked="_filterMarketingHigh" Label="Marketing Need 높음" Color="Color.Warning" Dense="true" Class="custom-checkbox ma-0" />
                <MudCheckBox @bind-Checked="_filterHasHiring" Label="채용 있음" Color="Color.Info" Dense="true" Class="custom-checkbox ma-0" />
                <MudCheckBox @bind-Checked="_filterNoHomepage" Label="홈페이지 없음" Color="Color.Primary" Dense="true" Class="custom-checkbox ma-0" />
                <MudCheckBox @bind-Checked="_filterNoSNS" Label="SNS 없음" Color="Color.Primary" Dense="true" Class="custom-checkbox ma-0" />
                <MudCheckBox @bind-Checked="_filterHasPhone" Label="전화 있음" Color="Color.Success" Dense="true" Class="custom-checkbox ma-0" />
                <MudCheckBox @bind-Checked="_filterExcludeSafeNum" Label="안심번호 제외" Color="Color.Default" Dense="true" Class="custom-checkbox ma-0" />
            </div>

            <MudSpacer />
            <MudButton Variant="Variant.Text" Size="Size.Small" Style="color: #888;" OnClick="ResetFilters">초기화</MudButton>
        </div>
        
        <MudOverlay Visible="_isCalculating" DarkBackground="true" Absolute="true" ZIndex="9999">
            <div class="d-flex flex-column align-center">
                <MudProgressCircular Color="Color.Secondary" Indeterminate="true" Size="Size.Large" Class="mb-4" />
                <MudText Typo="Typo.h6" Style="color: white; font-weight: bold;">영업 점수 AI 분석중...</MudText>
                <MudText Typo="Typo.body2" Style="color: #aaa;" Class="mt-2">마케팅필요도, 확장의지, 디지털 취약도 평가</MudText>
            </div>
        </MudOverlay>

        @* 타이틀 & 모드 버튼 *@
        <div class="d-flex align-center justify-space-between pa-2" style="background-color: #2a2a35; border-bottom: 1px solid #3d3d4b;">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.ListAlt" Color="Color.Info" Size="Size.Small" Class="mr-1" />
                <MudText Typo="Typo.subtitle2" Style="font-weight: bold; color: #e0e0e0; margin-right: 16px;">추출 리스트 (Core DB)</MudText>
                
                @* 모드 전환 버튼 *@
                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                    <MudButton OnClick="@(() => _currentMode = "DB")" Variant="@(_currentMode == "DB" ? Variant.Filled : Variant.Outlined)" Color="@(_currentMode == "DB" ? Color.Info : Color.Default)">DB 모드</MudButton>
                    <MudButton OnClick="@(() => _currentMode = "Analysis")" Variant="@(_currentMode == "Analysis" ? Variant.Filled : Variant.Outlined)" Color="@(_currentMode == "Analysis" ? Color.Secondary : Color.Default)">분석 모드</MudButton>
                </MudButtonGroup>
            </div>
            <div class="d-flex align-center" style="gap: 16px;">
                 @if (_isExtracting)
                 {
                     <MudText Typo="Typo.caption" Color="Color.Info">※ 목록 추출 진행중...</MudText>
                 }
                 else if (_isCalculating)
                 {
                     <MudText Typo="Typo.caption" Color="Color.Secondary">※ 영업 점수 AI 분석중...</MudText>
                 }
                 <MudButton Variant="Variant.Filled" Color="Color.Info" Size="Size.Small">옵션설정</MudButton>
            </div>
        </div>

        @* KPI Dashboard Bar *@
        <div class="d-flex align-center pa-2" style="background-color: #1a1a24; border-bottom: 1px solid #3d3d4b; gap: 8px;">
            <MudPaper Class="pa-2 d-flex flex-column align-center justify-center flex-grow-1" Style="background-color: #24242e; border: 1px solid #333340; box-shadow: none;">
                <MudText Typo="Typo.caption" Style="color: #aaa;">전체 업체</MudText>
                <MudText Typo="Typo.h6" Style="color: #4fc3f7; font-weight: bold;">@TotalFilteredCount <span style="font-size: 12px; color: #888;">개</span></MudText>
            </MudPaper>
            <MudPaper Class="pa-2 d-flex flex-column align-center justify-center flex-grow-1" Style="background-color: #24242e; border: 1px solid #333340; box-shadow: none;">
                <MudText Typo="Typo.caption" Style="color: #aaa;">휴대폰 확보율</MudText>
                <MudText Typo="Typo.h6" Style="color: #81c784; font-weight: bold;">@MobileRate <span style="font-size: 12px; color: #888;">%</span></MudText>
            </MudPaper>
            <MudPaper Class="pa-2 d-flex flex-column align-center justify-center flex-grow-1" Style="background-color: #24242e; border: 1px solid #333340; box-shadow: none;">
                <MudText Typo="Typo.caption" Style="color: #aaa;">이메일 확보율</MudText>
                <MudText Typo="Typo.h6" Style="color: #ba68c8; font-weight: bold;">@EmailRate <span style="font-size: 12px; color: #888;">%</span></MudText>
            </MudPaper>
            <MudPaper Class="pa-2 d-flex flex-column align-center justify-center flex-grow-1" Style="background-color: rgba(255, 82, 82, 0.05); border: 1px solid rgba(255, 82, 82, 0.2); box-shadow: none;">
                <MudText Typo="Typo.caption" Style="color: #ff8a65;">확신도 80 이상</MudText>
                <MudText Typo="Typo.h6" Style="color: #ff5252; font-weight: bold;">@HotLeadsCount <span style="font-size: 12px; color: #888;">개</span></MudText>
            </MudPaper>
        </div>

        <div class="d-flex flex-column flex-grow-1" style="min-height: 0; position: relative;">
            @* 결과 테이블 *@
            <MudTable T="ResultItem" Items="@FilteredResults" @bind-SelectedItems="_selectedResults" MultiSelection="true" Dense="true" Hover="true" Class="h-100" Style="background-color: #1e1e24; white-space: nowrap;" CustomHeader="true" RowStyleFunc="@GetRowStyle" OnRowClick="@(e => RowClicked(e))" FixedHeader="true" Height="100%">
                <HeaderContent>
                    <MudTHeadRow Style="background-color: #2a2a35; border-bottom: 1px solid #3d3d4b;">
                        @* 구분 컬럼들 (A. 기본 DB 영역) *@
                        <MudTh Style="color: #4fc3f7; white-space: nowrap; font-weight: bold; border-right: 1px solid #3d3d4b;">기본 정보</MudTh>
                    <MudTh Style="color: #b0b0c0; white-space: nowrap;">상호</MudTh>
                    <MudTh Style="color: #b0b0c0; white-space: nowrap;">업종</MudTh>
                    <MudTh Style="color: #b0b0c0; white-space: nowrap;">주소</MudTh>
                    <MudTh Style="color: #b0b0c0; white-space: nowrap;">우편번호</MudTh>
                    <MudTh Style="color: #b0b0c0; white-space: nowrap;">사업자번호</MudTh>
                    <MudTh Style="color: #b0b0c0; white-space: nowrap;">휴대폰번호</MudTh>
                    <MudTh Style="color: #b0b0c0; white-space: nowrap;">전화번호</MudTh>
                    <MudTh Style="color: #b0b0c0; white-space: nowrap;">이메일</MudTh>
                    <MudTh Style="color: #b0b0c0; white-space: nowrap; border-right: 1px solid #3d3d4b;">홈페이지</MudTh>
                    
                    @* 구분 컬럼들 (B. 점수 영역) *@
                    <MudTh Style="white-space: nowrap;">
                        <MudTooltip Placement="Placement.Top">
                            <ChildContent><span style="color: #ffca28; font-weight: bold; border-bottom: 1px dashed #aaa; cursor: help;">영업점수</span></ChildContent>
                            <TooltipContent><MudText Typo="Typo.caption">총 점수</MudText></TooltipContent>
                        </MudTooltip>
                    </MudTh>
                    <MudTh Style="white-space: nowrap;">
                        <MudTooltip Placement="Placement.Top">
                            <ChildContent><span style="color: #ffca28; border-bottom: 1px dashed #aaa; cursor: help;">마케팅필요도</span></ChildContent>
                            <TooltipContent>
                                <div class="text-left pa-2">
                                    <MudText Typo="Typo.caption" Style="display: block;">경쟁 업체 수</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">리뷰 수</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">지역 평균 리뷰 수</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">SNS 여부</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">홈페이지 여부</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block; font-weight: bold; color: #ffb74d;">최종 계산식 요약</MudText>
                                </div>
                            </TooltipContent>
                        </MudTooltip>
                    </MudTh>
                    <MudTh Style="white-space: nowrap;">
                        <MudTooltip Placement="Placement.Top">
                            <ChildContent><span style="color: #ffca28; border-bottom: 1px dashed #aaa; cursor: help;">확장의지</span></ChildContent>
                            <TooltipContent>
                                <div class="text-left pa-2">
                                    <MudText Typo="Typo.caption" Style="display: block;">최근 채용 공고 수</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">채용 등록일</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">지점 키워드 발견 여부</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">배달 플랫폼 신규 입점 여부</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block; font-weight: bold; color: #ffb74d;">점수 가중치 구성</MudText>
                                </div>
                            </TooltipContent>
                        </MudTooltip>
                    </MudTh>
                    <MudTh Style="white-space: nowrap;">
                        <MudTooltip Placement="Placement.Top">
                            <ChildContent><span style="color: #ffca28; border-bottom: 1px dashed #aaa; cursor: help;">디지털취약도</span></ChildContent>
                            <TooltipContent>
                                <div class="text-left pa-2">
                                    <MudText Typo="Typo.caption" Style="display: block;">사진 개수</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">메뉴 등록 여부</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">예약 기능 여부</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">홈페이지 여부</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">SNS 여부</MudText>
                                </div>
                            </TooltipContent>
                        </MudTooltip>
                    </MudTh>
                    <MudTh Style="white-space: nowrap;">
                        <MudTooltip Placement="Placement.Top">
                            <ChildContent><span style="color: #ffca28; border-bottom: 1px dashed #aaa; cursor: help;">타이밍</span></ChildContent>
                            <TooltipContent>
                                <div class="text-left pa-2">
                                    <MudText Typo="Typo.caption" Style="display: block;">최근 30일 리뷰 증감률</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">별점 변화</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">경쟁 신규 매장 수</MudText>
                                    <MudText Typo="Typo.caption" Style="display: block;">최근 채용 종료 여부</MudText>
                                </div>
                            </TooltipContent>
                        </MudTooltip>
                    </MudTh>
                </MudTHeadRow>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="기본 정보" Style="color: #555; font-size: 11px; text-align: center; border-right: 1px solid #3d3d4b;">[A]</MudTd>
                <MudTd DataLabel="상호" Style="color: #e0e0e0; font-size: 12px; font-weight: bold; cursor: pointer;">@context.CompanyName</MudTd>
                <MudTd DataLabel="업종" Style="color: #888; font-size: 12px; cursor: pointer;">@context.IndustryClass</MudTd>
                <MudTd DataLabel="주소" Style="color: #888; font-size: 12px; cursor: pointer;">@context.Address</MudTd>
                <MudTd DataLabel="우편번호" Style="color: #888; font-size: 12px; cursor: pointer;">@context.ZipCode</MudTd>
                <MudTd DataLabel="사업자번호" Style="color: #888; font-size: 12px; cursor: pointer;">@context.BizNo</MudTd>
                <MudTd DataLabel="휴대폰번호" Style="color: #e0e0e0; font-size: 12px; cursor: pointer;">@context.Mobile</MudTd>
                <MudTd DataLabel="전화번호" Style="color: #e0e0e0; font-size: 12px; cursor: pointer;">@context.Phone</MudTd>
                <MudTd DataLabel="이메일" Style="color: #888; font-size: 12px; cursor: pointer;">@context.Email</MudTd>
                <MudTd DataLabel="홈페이지" Style="color: #888; font-size: 12px; border-right: 1px solid #3d3d4b; cursor: pointer;">@context.Homepage</MudTd>
                
                <MudTd DataLabel="영업점수" Style="font-weight: bold; font-size: 13px; cursor: pointer;">
                    @if (context.SalesScore.HasValue)
                    {
                        @if (context.SalesScore >= 80)
                        {
                            <span style="color: #ff5252;">@context.SalesScore</span>
                        }
                        else if (context.SalesScore >= 70)
                        {
                            <span style="color: #ffb74d;">@context.SalesScore</span>
                        }
                        else if (context.SalesScore >= 60)
                        {
                            <span style="color: #fff176;">@context.SalesScore</span>
                        }
                        else
                        {
                            <span style="color: #aaa;">@context.SalesScore</span>
                        }
                    }
                    else
                    {
                        <span style="color: #555;">-</span>
                    }
                </MudTd>
                <MudTd DataLabel="마케팅필요도" Style="color: #ccc; font-size: 12px; cursor: pointer;">@(context.MarketingNeedScore?.ToString() ?? "-")</MudTd>
                <MudTd DataLabel="확장의지" Style="color: #ccc; font-size: 12px; cursor: pointer;">@(context.ExpansionScore?.ToString() ?? "-")</MudTd>
                <MudTd DataLabel="디지털취약도" Style="color: #ccc; font-size: 12px; cursor: pointer;">@(context.DigitalVulnerabilityScore?.ToString() ?? "-")</MudTd>
                <MudTd DataLabel="타이밍" Style="color: #ccc; font-size: 12px; cursor: pointer;">@(context.TimingScore?.ToString() ?? "-")</MudTd>

            </RowTemplate>
            <NoRecordsContent>
                <div style="height: 300px; display: flex; align-items: center; justify-content: center;">
                    <MudText Typo="Typo.caption" Style="color: #555;">조회된 데이터가 없습니다.</MudText>
                </div>
            </NoRecordsContent>
        </MudTable>
        </div>

        @* 하단 툴바 *@
        <div class="d-flex align-center justify-space-between pa-2" style="background-color: #2a2a35; border-top: 1px solid #3d3d4b;">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Style="color: #4fc3f7; margin-right: 4px;" />
                <MudText Typo="Typo.caption" Style="color: #e0e0e0;"><strong style="color: #4fc3f7;">@FilteredResults.Count()</strong> 건의 데이터가 검색되었습니다.</MudText>
            </div>
            
            <div class="d-flex align-center" style="gap: 8px;">
                <MudButton Variant="Variant.Filled" Color="Color.Info" StartIcon="@Icons.Material.Filled.PlayArrow" OnClick="StartExtraction1" Disabled="@_isExtracting">추출시작</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.AutoGraph" OnClick="StartExtraction2" Disabled="@(_resultList.Count == 0 || _isCalculating)">영업 점수 계산</MudButton>
                <MudButton Variant="Variant.Filled" Style="background-color: #555566; color: white;" OnClick="StopWork" Disabled="@(!_isExtracting && !_isCalculating)">작업정지</MudButton>
                <MudButton Variant="Variant.Filled" Style="background-color: #555566; color: white;" OnClick="RemoveSelectedResults" Disabled="@(_selectedResults.Count == 0)">선택삭제</MudButton>
                <MudButton Variant="Variant.Filled" Style="background-color: #555566; color: white;" StartIcon="@Icons.Material.Filled.Download">엑셀저장</MudButton>
            </div>
        </div>
    </MudPaper>

</div>

@* --- 우측 Quick View 드로어 (행 클릭시 열림) --- *@
<MudDrawer @bind-Open="_isQuickViewOpen" Anchor="Anchor.End" Elevation="3" Variant="DrawerVariant.Temporary" Width="380px" Style="background-color: #1a1a24; border-left: 1px solid #3d3d4b; z-index: 100000;">
    @if (_selectedItemForView != null)
    {
        <div class="pa-4 d-flex flex-column h-100" style="color: #e0e0e0; overflow-y: auto;">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Style="font-weight: bold; color: white;">Sales 퀵뷰</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" OnClick="@(() => _isQuickViewOpen = false)" Size="Size.Small" />
            </div>
            
            <MudText Typo="Typo.h5" Style="color: #4fc3f7; font-weight: bold;">@_selectedItemForView.CompanyName</MudText>
            <MudText Typo="Typo.body2" Class="mb-4" Style="color: #aaa;">@_selectedItemForView.IndustryClass | 사업자: @_selectedItemForView.BizNo</MudText>

            @* Sales Score Big Display *@
            <MudPaper Class="pa-4 mb-4 d-flex flex-column align-center" Style="background-color: #24242e; border: 1px solid #3d3d4b;">
                <MudText Typo="Typo.subtitle2" Style="color: #bbb;">Total Sales Score</MudText>
                <MudText Typo="Typo.h2" Style="@GetScoreColorStyle(_selectedItemForView.SalesScore, true)">
                    @(_selectedItemForView.SalesScore?.ToString() ?? "-")
                </MudText>
                @if(_selectedItemForView.SalesScore >= 80)
                {
                    <MudChip Color="Color.Error" Size="Size.Small" Class="mt-2 text-uppercase font-weight-bold">Hot Lead</MudChip>
                }
            </MudPaper>

            @* 5 Score Bars *@
            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: #ddd;">세부 가치 분석</MudText>
            <div class="mb-5 pa-3 pb-4" style="background-color: #24242e; border: 1px solid #3d3d4b; border-radius: 4px;">
                @ScoreBarTemplate(("영업점수", _selectedItemForView.SalesScore))
                @ScoreBarTemplate(("마케팅필요도", _selectedItemForView.MarketingNeedScore))
                @ScoreBarTemplate(("확장의지", _selectedItemForView.ExpansionScore))
                @ScoreBarTemplate(("디지털취약도", _selectedItemForView.DigitalVulnerabilityScore))
                @ScoreBarTemplate(("타이밍", _selectedItemForView.TimingScore))
            </div>

            @* Meta Info *@
            <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: #ddd;">영업 핵심 지표</MudText>
            <MudPaper Class="pa-3 mb-4" Style="background-color: #24242e; border: 1px solid #3d3d4b;">
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body2" Style="color: #bbb;">리뷰 변화</MudText>
                    <MudText Typo="Typo.body2" Style="color: #81c784; font-weight: bold;">
                        @(_selectedItemForView.ReviewTrend >= 0 ? "+" : "")@_selectedItemForView.ReviewTrend 건/월
                    </MudText>
                </div>
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body2" Style="color: #bbb;">채용 여부</MudText>
                    <MudText Typo="Typo.body2" Style="@(_selectedItemForView.HasHiring ? "color: #ffb74d; font-weight: bold;" : "color: #aaa;")">
                        @(_selectedItemForView.HasHiring ? "채용 진행중" : "없음")
                    </MudText>
                </div>
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body2" Style="color: #bbb;">전화번호</MudText>
                    <div style="text-align: right;">
                        <MudText Typo="Typo.body2" Style="color: #e0e0e0;">@_selectedItemForView.Phone</MudText>
                        @if(_selectedItemForView.HasSafeNumber) { <MudText Typo="Typo.caption" Color="Color.Warning">안심번호</MudText> }
                    </div>
                </div>
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body2" Style="color: #bbb;">휴대폰번호</MudText>
                    <MudText Typo="Typo.body2" Style="color: #e0e0e0;">@_selectedItemForView.Mobile</MudText>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2" Style="color: #bbb;">이메일</MudText>
                    <MudText Typo="Typo.body2" Style="color: #e0e0e0;">@_selectedItemForView.Email</MudText>
                </div>
            </MudPaper>

            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.SmartToy" FullWidth="true" Class="py-3 mt-4" Style="font-weight: bold; letter-spacing: 1px;">AI 영업 맞춤 스크립트 작성</MudButton>
        </div>
    }
</MudDrawer>



