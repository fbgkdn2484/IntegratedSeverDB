@code {
    private RenderFragment<(string label, int? score)> ScoreBarTemplate => context => __builder =>
    {
        int s = context.score ?? 0;
        string color = s >= 80 ? "#ff5252" : (s >= 70 ? "#ffb74d" : (s >= 60 ? "#fff176" : "#666"));
        <div class="d-flex align-center mb-2">
            <div style="width: 80px; color: #aaa; font-size: 12px;">@context.label</div>
            <div class="flex-grow-1 mx-3" style="height: 6px; background-color: #333340; border-radius: 3px; overflow: hidden; position: relative;">
                <div style="position: absolute; left: 0; top: 0; height: 100%; width: @(s)%; background-color: @color; transition: width 0.5s ease;"></div>
            </div>
            <div style="width: 30px; text-align: right; color: @color; font-size: 13px; font-weight: bold;">
                @(s > 0 ? s.ToString() : "-")
            </div>
        </div>
    };

    protected override void OnInitialized()
    {
        // 초기 임의 목업 데이터 등록
        LoadMockData();
    }

    private void LoadMockData()
    {
        var rnd = new Random();
        string[] industryClasses = { "정보통신업", "전문과학기술", "도소매업", "제조업", "건설업" };
        string[] locations = { "서울 서초구", "서울 강남구", "판교 테크노밸리", "부산 해운대구", "대전 유성구" };
        
        for (int i = 1; i <= 35; i++)
        {
            _resultList.Add(new ResultItem
            {
                Id = i,
                CompanyName = $"테스트 파트너스 {i}{(i % 3 == 0 ? "(주)" : "")}",
                IndustryClass = industryClasses[rnd.Next(industryClasses.Length)],
                Address = $"{locations[rnd.Next(locations.Length)]} ...",
                ZipCode = $"06{rnd.Next(100, 999)}",
                BizNo = $"{rnd.Next(100, 999)}-{rnd.Next(10, 99)}-{rnd.Next(10000, 99999)}",
                Mobile = i % 4 == 0 ? "" : $"010-{rnd.Next(1000, 9999)}-{rnd.Next(1000, 9999)}",
                Phone = i % 5 == 0 ? "" : $"02-{rnd.Next(100, 999)}-{rnd.Next(1000, 9999)}",
                Email = i % 3 == 0 ? "" : $"contact{i}@example.com",
                Homepage = i % 4 == 0 ? "" : $"www.test{i}.com",
                
                // 설정된 초기엔 전부 비움
                SalesScore = null,
                MarketingNeedScore = null,
                ExpansionScore = null,
                DigitalVulnerabilityScore = null,
                TimingScore = null,
                
                // Quick View / Filter Meta Dummy Data
                HasHiring = i % 3 == 0,
                HasSNS = i % 2 == 0,
                HasSafeNumber = i % 6 == 0,
                ReviewTrend = rnd.Next(-5, 30),
            });
        }
    }

    private string GetRowStyle(ResultItem item, int index)
    {
        if (!item.SalesScore.HasValue) return "";
        
        // 80↑ Red, 70↑ Orange, 60↑ Yellow Row tint
        if (item.SalesScore >= 80) return "background-color: rgba(255, 82, 82, 0.08);";
        if (item.SalesScore >= 70) return "background-color: rgba(255, 183, 77, 0.08);";
        if (item.SalesScore >= 60) return "background-color: rgba(255, 241, 118, 0.05);";
        
        return "";
    }

    private string GetScoreColorStyle(int? score, bool isBig = false)
    {
        if (!score.HasValue) return "color: #555;"; 
        if (score >= 80) return isBig ? "color: #ff5252; font-weight: 900;" : "color: #ff5252;";
        if (score >= 70) return isBig ? "color: #ffb74d; font-weight: 900;" : "color: #ffb74d;";
        if (score >= 60) return isBig ? "color: #fff176; font-weight: 900;" : "color: #fff176;";
        return "color: #aaa;";
    }

    // --- 상단 검색 모듈 ---
    private DateTime? _startDate;
    private DateTime? _endDate;
    private string _selectedRegion1 = "전국";
    private string _selectedRegion2 = "전체";
    private string _selectedIndustry = "-전체-";
    private string _searchCompanyName = "";

    // --- 필터 패널 변수 ---
    private bool _filterSalesScore70 = false;
    private bool _filterMarketingHigh = false;
    private bool _filterHasHiring = false;
    private bool _filterNoHomepage = false;
    private bool _filterNoSNS = false;
    private bool _filterHasPhone = false;
    private bool _filterExcludeSafeNum = false;

    private void ResetFilters()
    {
        _filterSalesScore70 = false;
        _filterMarketingHigh = false;
        _filterHasHiring = false;
        _filterNoHomepage = false;
        _filterNoSNS = false;
        _filterHasPhone = false;
        _filterExcludeSafeNum = false;
    }

    // --- 데이터 그리드 ---
    private List<ResultItem> _resultList = new();
    private HashSet<ResultItem> _selectedResults = new();
    
    private bool _isExtracting = false;
    private bool _isCalculating = false;

    private string _currentMode = "DB";

    // 필터링된 결과
    private IEnumerable<ResultItem> FilteredResults
    {
        get
        {
            var query = _resultList.Where(r => 
                (!_filterSalesScore70 || (r.SalesScore.HasValue && r.SalesScore.Value >= 70)) &&
                (!_filterMarketingHigh || (r.MarketingNeedScore.HasValue && r.MarketingNeedScore.Value >= 70)) &&
                (!_filterHasHiring || r.HasHiring) &&
                (!_filterNoHomepage || string.IsNullOrWhiteSpace(r.Homepage)) &&
                (!_filterNoSNS || !r.HasSNS) &&
                (!_filterHasPhone || !string.IsNullOrWhiteSpace(r.Phone) || !string.IsNullOrWhiteSpace(r.Mobile)) &&
                (!_filterExcludeSafeNum || !r.HasSafeNumber)
            );

            if (_currentMode == "Analysis")
            {
                return query.OrderByDescending(x => x.SalesScore ?? 0).ThenByDescending(x => x.Id);
            }
            else
            {
                // DB 모드: 연락처 중심 정렬 (휴대폰 있는 경우 우선)
                return query.OrderByDescending(x => !string.IsNullOrWhiteSpace(x.Mobile))
                            .ThenByDescending(x => !string.IsNullOrWhiteSpace(x.Email))
                            .ThenBy(x => x.Id);
            }
        }
    }

    private int TotalFilteredCount => FilteredResults.Count();
    private int MobileRate => TotalFilteredCount == 0 ? 0 : (FilteredResults.Count(x => !string.IsNullOrWhiteSpace(x.Mobile)) * 100) / TotalFilteredCount;
    private int EmailRate => TotalFilteredCount == 0 ? 0 : (FilteredResults.Count(x => !string.IsNullOrWhiteSpace(x.Email)) * 100) / TotalFilteredCount;
    private int HotLeadsCount => FilteredResults.Count(x => x.SalesScore >= 80);

    // --- Quick View 토글 ---
    private bool _isQuickViewOpen = false;
    private ResultItem _selectedItemForView = new ResultItem();

    private void RowClicked(TableRowClickEventArgs<ResultItem> args)
    {
        _selectedItemForView = args.Item;
        _isQuickViewOpen = true;
    }

    // --- 기능 ---
    private async Task StartExtraction1()
    {
        _isExtracting = true;
        StateHasChanged();

        await Task.Delay(1500); 
        
        var rnd = new Random();
        int startIndex = _resultList.Count > 0 ? _resultList.Max(x => x.Id) + 1 : 1;
        
        string baseKeyword = string.IsNullOrWhiteSpace(_searchCompanyName) ? "테스트" : _searchCompanyName;
        string industry = _selectedIndustry == "-전체-" ? "일반 기업" : _selectedIndustry;

        int count = rnd.Next(5, 12);
        for (int i = 0; i < count; i++)
        {
            _resultList.Add(new ResultItem
            {
                Id = startIndex++,
                CompanyName = $"{baseKeyword} 솔루션 {i+1}",
                IndustryClass = industry,
                Address = $"{_selectedRegion1} {_selectedRegion2} 상세주소...",
                ZipCode = $"05{rnd.Next(100, 999)}",
                BizNo = $"{rnd.Next(100, 999)}-{rnd.Next(10, 99)}-{rnd.Next(10000, 99999)}",
                Mobile = $"010-{rnd.Next(1000, 9999)}-{rnd.Next(1000, 9999)}",
                Phone = $"02-{rnd.Next(100,999)}-{rnd.Next(1000,9999)}",
                Email = $"contact@{baseKeyword.ToLower()}.com",
                Homepage = $"www.{baseKeyword.ToLower()}.com",
                
                HasHiring = rnd.Next(2) == 0,
                HasSNS = rnd.Next(2) == 0,
                HasSafeNumber = rnd.Next(5) == 0,
                ReviewTrend = rnd.Next(-2, 25),
            });
        }

        _isExtracting = false;
        StateHasChanged();
    }

    private async Task StartExtraction2()
    {
        if (_resultList.Count == 0 || _isCalculating) return;
        
        _isCalculating = true;
        StateHasChanged();

        await Task.Delay(2500); 

        var rnd = new Random();
        foreach (var result in _resultList)
        {
            result.MarketingNeedScore = rnd.Next(40, 100);
            result.ExpansionScore = rnd.Next(30, 90);
            result.DigitalVulnerabilityScore = rnd.Next(50, 95);
            result.TimingScore = rnd.Next(20, 100);
            
            // 종합 점수 계산 (가중치 샘플)
            int total = (int)(
                result.MarketingNeedScore.Value * 0.3 +
                result.DigitalVulnerabilityScore.Value * 0.3 +
                result.ExpansionScore.Value * 0.2 +
                result.TimingScore.Value * 0.2
            );
            
            // 확신의 랜덤 플러스 마이너스
            total += rnd.Next(-5, 6);
            if (total > 100) total = 100;
            if (total < 20) total = 20;

            result.SalesScore = total;
        }

        _isCalculating = false;
        StateHasChanged();
    }

    private void StopWork()
    {
        _isExtracting = false;
        _isCalculating = false;
        StateHasChanged();
    }

    private void RemoveSelectedResults()
    {
        _resultList.RemoveAll(x => _selectedResults.Contains(x));
        _selectedResults.Clear();
        int idx = 1;
        foreach (var item in _resultList) item.Id = idx++;
    }

    // --- 모델들 ---
    public class ResultItem
    {
        public int Id { get; set; }
        
        // 검색된 내용
        public string CompanyName { get; set; } = "";
        public string IndustryClass { get; set; } = "";
        public string Address { get; set; } = "";
        public string ZipCode { get; set; } = "";
        public string BizNo { get; set; } = "";
        public string Mobile { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Email { get; set; } = "";
        public string Homepage { get; set; } = "";
        
        // 5가지 점수
        public int? SalesScore { get; set; }
        public int? MarketingNeedScore { get; set; }
        public int? ExpansionScore { get; set; }
        public int? DigitalVulnerabilityScore { get; set; }
        public int? TimingScore { get; set; }
        
        // 추가 메타
        public bool HasHiring { get; set; }
        public bool HasSNS { get; set; }
        public bool HasSafeNumber { get; set; }
        public int ReviewTrend { get; set; }
        
        public override bool Equals(object? obj) => obj is ResultItem i && i.Id == Id;
        public override int GetHashCode() => Id.GetHashCode();
    }
}
